begin
  -- Use CTEs to get ranked results from each search type
  return query
  with vector_search as (
    select
      dv2.id,
      (1 - (dv2.embedding <=> query_embedding))::float as similarity_score,
      rank() over (order by dv2.embedding <=> query_embedding asc) as rank
    from documents_v2 dv2
    where metadata @> filter
    order by similarity_score desc
    limit match_count * 2
  ),
  keyword_search as (
    select
      dv2.id,
      ts_rank(fts, websearch_to_tsquery('english', query_text))::float as keyword_score,
      rank() over (order by ts_rank(fts, websearch_to_tsquery('english', query_text)) desc) as rank
    from documents_v2 dv2
    where metadata @> filter and fts @@ websearch_to_tsquery('english', query_text)
    order by keyword_score desc
    limit match_count * 2
  )
  
  select
    docs.id,
    docs.content,
    docs.metadata,
    coalesce(vector_search.similarity_score, 0.0) as vector_score,
    coalesce(keyword_search.keyword_score, 0.0) as keyword_score,
    vector_search.rank as vector_rank,
    keyword_search.rank as keyword_rank,
    (
      coalesce(1.0 / (rrf_k + vector_search.rank), 0.0) +
      coalesce(1.0 / (rrf_k + keyword_search.rank), 0.0)
    )::double precision as final_score
  from vector_search
  full outer join keyword_search on vector_search.id = keyword_search.id
  join documents_v2 docs on docs.id = coalesce(vector_search.id, keyword_search.id)
  
  -- Order by the final combined score
  order by final_score desc
  limit match_count; -- Apply final limit
end;
